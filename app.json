{
  "expo": {
    "name": "VibeSDR",
    "slug": "VibeSDR",
    "version": "3.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vibesdr.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "VibeSDR uses your location to show distance to each SDR instance and sort by nearest first.",
        "NSLocalNetworkUsageDescription": "VibeSDR needs local network access to connect to SDR hardware.",
        "UIBackgroundModes": [
          "audio"
        ],
        "NSBonjourServices": [
          "_http._tcp",
          "_https._tcp"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.vibesdr.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A12",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "117da7dc-3041-493f-a4d2-b79fa2fed326"
      }
    },
    "owner": "stuey3d"
  }
}