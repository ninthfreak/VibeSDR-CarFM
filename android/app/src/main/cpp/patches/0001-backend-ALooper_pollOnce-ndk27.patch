# NDK 27 marks ALooper_pollAll() unavailable; use the signature-identical
# ALooper_pollOnce(). Apply from the SDR++ Brown source root:
#   git apply <this>   (or: patch -p1 < this)
--- a/core/backends/android/backend.cpp
+++ b/core/backends/android/backend.cpp
@@ -167,7 +167,7 @@
             int out_events;
             struct android_poll_source* out_data;
 
-            while (ALooper_pollAll(0, NULL, &out_events, (void**)&out_data) >= 0) {
+            while (ALooper_pollOnce(0, NULL, &out_events, (void**)&out_data) >= 0) {
                 // Process one event
                 if (out_data != NULL) { out_data->process(app, out_data); }
 
